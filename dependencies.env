# TalkText dependency contract.
#
# This file is sourced by scripts/dependency-tool.sh. Keep values as quoted,
# literal shell assignments. Updating a dependency is a reviewed change: update
# its pinned metadata, run the dependency fixture tests, and record backend
# compatibility evidence in the release notes.

TALKTEXT_DEPENDENCY_MANIFEST_VERSION='1'

# Model: https://huggingface.co/ggerganov/whisper.cpp
MODEL_REPOSITORY='ggerganov/whisper.cpp'
MODEL_REVISION='80da2d8bfee42b0e836fc3a9890373e5defc00a6'
MODEL_FILE_NAME='ggml-base.en.bin'
MODEL_URL='https://huggingface.co/ggerganov/whisper.cpp/resolve/80da2d8bfee42b0e836fc3a9890373e5defc00a6/ggml-base.en.bin'
MODEL_SIZE_BYTES='147964211'
MODEL_SHA256='a03779c86df3323075f5e796cb2ce5029f00ec8869eee3fdfb897afe36c6d002'
# GGML files begin with the little-endian bytes for the uint32 magic 0x67676d6c.
MODEL_MAGIC_HEX='6c6d6767'

# Backend contract. Every supported version is pinned to its upstream revision
# so CI can build the exact backend rather than relying on a moving formula.
# TalkText also requires every production flag below in `whisper-cli --help`.
BACKEND_FORMULA='whisper-cpp'
BACKEND_EXECUTABLE='whisper-cli'
BACKEND_REPOSITORY_URL='https://github.com/ggml-org/whisper.cpp.git'
BACKEND_SUPPORTED_VERSIONS='1.8.4 1.9.1'
BACKEND_UPSTREAM_REVISIONS='1.8.4=9386f239401074690479731c1e41683fbbeac557 1.9.1=f049fff95a089aa9969deb009cdd4892b3e74916'
BACKEND_REQUIRED_FLAGS='--model --file --no-timestamps --threads'
