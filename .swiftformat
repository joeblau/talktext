--swiftversion 6.0
--indent 4
--maxwidth 160
--commas always
--exclude TalkText/.build,TalkText/.swiftpm

# Existing code intentionally relies on these spellings or layouts. The
# remaining enabled rules are the repository's enforced formatting policy.
--disable blankLinesBetweenScopes,elseOnSameLine,modifierOrder,numberFormatting,preferKeyPath,redundantReturn,redundantSelf,sortImports,spaceAroundOperators,unusedArguments,wrapMultilineStatementBraces
