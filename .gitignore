# CFBundleName change cannot leave the bundle tracked.
*.app/

# Development Xcode project generated by scripts/generate-xcodeproj.sh
*.xcodeproj/

# Local signing identity written by scripts/generate-xcodeproj.sh. Holds a
# machine-specific development team.
/Local.xcconfig

# Downloaded Whisper model
models/
